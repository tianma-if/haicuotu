---
import Layout from '../../layouts/Layout.astro';
import SharePoster from '../../components/SharePoster';
import { allCreatures, getCreatureMeta, type Creature } from '../../utils/data';
import { ChevronLeft, Flame, ShieldAlert, Award, BookOpen, Compass } from 'lucide-react';

export async function getStaticPaths() {
  return allCreatures.map(c => ({
    params: { id: c.id },
    props: { creature: c }
  }));
}

interface Props {
  creature: Creature;
}

const { creature } = Astro.props;
const meta = getCreatureMeta(creature);
---

<Layout 
  title={`${creature.name} - 《海错图》智能图鉴`} 
  description={`清代聂璜《海错图》第${creature.volume}册记载的神秘生物——${creature.name}。包含古文释义：${creature.description.slice(0, 80)}`}
>
  <div class="space-y-6">
    <!-- Breadcrumb & Back button -->
    <a href="/" class="inline-flex items-center gap-1 text-xs font-bold text-ink-black/60 hover:text-cinnabar-red transition-colors duration-200">
      <ChevronLeft class="w-4 h-4" /> 返回画廊图鉴
    </a>

    <!-- Main Detail Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left Column: Visual card & Sharing button (4 cols) -->
      <div class="lg:col-span-5 space-y-6">
        <!-- Main Card Image -->
        <div class="bg-paper-light border-2 border-ink-black shadow-md p-4 rounded-sm">
          <div class="bg-white border border-paper-dark/40 aspect-[4/3] rounded-sm overflow-hidden flex items-center justify-center relative">
            {creature.image ? (
              <img
                src={creature.image}
                alt={creature.name}
                class="object-cover w-full h-full"
              />
            ) : (
              <div class="text-center p-8">
                <p class="font-display text-2xl text-ink-black/30">书卷白描图缺</p>
                <p class="text-xs text-ink-black/40 font-sans mt-2">（此页为纯前言/目录文字）</p>
              </div>
            )}
            <div class="absolute top-3 right-3 bg-cinnabar-red text-paper-light px-2.5 py-1 text-xs font-display font-bold shadow-md rounded-sm">
              第一册 • 第 {creature.page_idx} 开
            </div>
          </div>

          <div class="mt-4 text-center border-t border-paper-dark/30 pt-3 text-xs text-ink-black/50 font-sans">
            聂璜 绘于康熙戊寅年（1698年）
          </div>
        </div>

        <!-- Sharing Card Component -->
        <SharePoster client:load creature={creature} />
      </div>

      <!-- Right Column: Texts & Ancient Scroll (7 cols) -->
      <div class="lg:col-span-7 space-y-6">
        <!-- Title Header -->
        <div class="flex flex-wrap items-end justify-between gap-4 border-b border-paper-dark/40 pb-4">
          <div class="space-y-1">
            <span class="text-xs font-bold bg-deep-sea text-paper-light px-2 py-0.5 rounded-full font-sans uppercase tracking-widest">
              {meta.category}
            </span>
            <h2 class="font-display text-4xl md:text-5xl font-black text-cinnabar-red tracking-wide">
              {creature.name}
            </h2>
          </div>
          <div class="text-right text-xs text-ink-black/60 font-sans">
            <span class="block">出处：故宫博物院藏本</span>
            <span class="block font-bold mt-0.5">第 {creature.volume} 册</span>
          </div>
        </div>

        <!-- Attributes card panel -->
        <div class="grid grid-cols-2 gap-4 bg-paper-light border border-paper-dark/30 p-4 rounded-sm">
          <div class="flex items-center gap-3">
            <div class="bg-cinnabar-red/10 p-2.5 rounded-sm">
              <Flame class="w-6 h-6 text-cinnabar-red fill-current" />
            </div>
            <div>
              <span class="block text-[10px] text-ink-black/50 font-sans font-bold">美味度</span>
              <span class="font-sans text-sm font-bold">
                {'★'.repeat(meta.delicious)}{'☆'.repeat(5 - meta.delicious)}
              </span>
            </div>
          </div>

          <div class="flex items-center gap-3">
            <div class="bg-deep-sea/10 p-2.5 rounded-sm">
              <ShieldAlert class="w-6 h-6 text-deep-sea fill-current" />
            </div>
            <div>
              <span class="block text-[10px] text-ink-black/50 font-sans font-bold">危险危险度</span>
              <span class="font-sans text-sm font-bold">
                {'★'.repeat(meta.danger)}{'☆'.repeat(5 - meta.danger)}
              </span>
            </div>
          </div>
        </div>

        <!-- Ancient text segment (Classical reading Scroll) -->
        <div class="bg-[#faf6eb] border-2 border-ink-black/85 p-6 rounded-sm shadow-inner relative overflow-hidden">
          <div class="absolute top-0 right-0 bg-[#ebdcb9] text-ink-black/60 font-display text-[10px] font-bold px-2 py-0.5 border-b border-l border-ink-black/85 rounded-bl-sm">
            古籍誊录
          </div>
          
          <h3 class="font-display text-lg font-bold text-deep-sea flex items-center gap-1.5 mb-3">
            <BookOpen class="w-4 h-4" /> 聂璜 《海错图》 原文记载：
          </h3>

          <!-- Text block -->
          <div class="font-display text-base md:text-lg leading-relaxed text-ink-black/90 tracking-wide bg-white/50 p-4 rounded-sm border border-paper-dark/30 shadow-sm min-h-[120px]">
            {creature.description}
          </div>
        </div>

        <!-- Modern scientific interpretation -->
        <div class="bg-paper-light border border-paper-dark/35 p-6 rounded-sm space-y-4">
          <h3 class="font-display text-lg font-bold text-deep-sea flex items-center gap-1.5 border-b border-paper-dark/20 pb-2">
            <Compass class="w-4 h-4" /> 现代生物对照与考证：
          </h3>
          
          <div class="space-y-3 text-xs md:text-sm font-sans text-ink-black/85 leading-relaxed">
            <p>
              <span class="font-bold text-deep-sea">【生态解读】</span> {meta.modernInfo}
            </p>
            <p>
              <span class="font-bold text-cinnabar-red">【食味评价】</span> {meta.deliciousComment}
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>

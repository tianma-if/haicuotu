---
import Layout from '../../layouts/Layout.astro';
import { allCreatures, getCreatureMeta, type Creature } from '../../utils/data';
import { ChevronLeft, Flame, ShieldAlert, BookOpen } from 'lucide-react';

export async function getStaticPaths() {
  return allCreatures.map(c => ({
    params: { id: c.id },
    props: { creature: c }
  }));
}

interface Props {
  creature: Creature;
}

const { creature } = Astro.props;
const meta = getCreatureMeta(creature);
const identification = meta.modernIdentification;
const modernImage = identification?.modernImage;
const sourceName = creature.volume === 4 ? '台北故宫博物院藏本' : '故宫博物院藏本';
const title = `${creature.name} - 《海错图》数字化图鉴与现代考证`;
const description = `《海错图》第${creature.volume}册${creature.name}条目，含聂璜原文释义、${meta.category}分类、古今生物对照与食味危险指数。${creature.description.slice(0, 70)}`;
const canonical = `/creatures/${creature.id}`;
---

<Layout 
  title={title}
  description={description}
  canonical={canonical}
  image={creature.image}
  imageAlt={`《海错图》${creature.name}插图`}
  type="article"
  keywords={["海错图", creature.name, "聂璜", meta.category, "古籍数字化", "海洋生物", "现代考证"]}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "url": new URL(canonical, Astro.site).toString(),
    "image": creature.image ? new URL(creature.image, Astro.site).toString() : undefined,
    "inLanguage": "zh-CN",
    "author": {
      "@type": "Organization",
      "name": "Haicuotu Project"
    },
    "isPartOf": {
      "@type": "WebSite",
      "name": "海错图数字化图鉴",
      "url": new URL("/", Astro.site).toString()
    },
    "about": [creature.name, meta.category, "海错图", "清代博物图谱"]
  }}
>
  <div class="space-y-5 md:space-y-6">
    <!-- Breadcrumb & Back button -->
    <a href="/" class="inline-flex items-center gap-1 text-xs font-bold text-ink-black/60 hover:text-cinnabar-red transition-colors duration-200">
      <ChevronLeft class="w-4 h-4" /> 返回画廊图鉴
    </a>

    <!-- Main Detail Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start">
      <!-- Left Column: Visual card, intentionally dominant on detail pages -->
      <div class="lg:col-span-8 space-y-6">
        <!-- Main Card Image -->
        <div class="bg-paper-light border-2 border-ink-black shadow-md p-3 md:p-4 rounded-sm">
          <div class="bg-white border border-paper-dark/40 aspect-[4/3] rounded-sm overflow-hidden flex items-center justify-center relative">
            {creature.image ? (
              <img
                src={creature.image}
                alt={`${creature.name}海错图原图`}
                class="object-contain w-full h-full p-3"
              />
            ) : (
              <div class="text-center p-8">
                <p class="font-display text-2xl text-ink-black/30">书卷白描图缺</p>
                <p class="text-xs text-ink-black/40 font-sans mt-2">（当前尚未核定可对应此条的独立插图）</p>
              </div>
            )}
            <div class="absolute top-3 right-3 bg-cinnabar-red text-paper-light px-2.5 py-1 text-xs font-display font-bold shadow-md rounded-sm">
              第 {creature.volume} 册 • 第 {creature.page_idx} 开
            </div>
          </div>

          <div class="mt-4 text-center border-t border-paper-dark/30 pt-3 text-xs text-ink-black/50 font-sans">
            聂璜 绘于康熙戊寅年（1698年）
          </div>
        </div>
      </div>

      <!-- Right Column: Compact notes -->
      <div class="lg:col-span-4 space-y-3 md:space-y-4">
        <!-- Title Header -->
        <div class="flex flex-wrap items-end justify-between gap-4 border-b border-paper-dark/40 pb-3">
          <div class="space-y-1">
            <span class="text-[10px] font-bold bg-deep-sea text-paper-light px-2 py-0.5 rounded-full font-sans uppercase tracking-widest">
              {meta.category}
            </span>
            <h2 class="font-display text-3xl md:text-4xl font-black text-cinnabar-red tracking-wide">
              {creature.name}
            </h2>
          </div>
          <div class="text-right text-[10px] text-ink-black/60 font-sans">
            <span class="block">出处：{sourceName}</span>
            <span class="block font-bold mt-0.5">第 {creature.volume} 册</span>
          </div>
        </div>

        <!-- Compact attributes -->
        <div class="flex flex-wrap items-center gap-2 text-[11px] font-sans">
          <div class="inline-flex items-center gap-1.5 rounded-full bg-cinnabar-red/8 border border-cinnabar-red/20 px-2.5 py-1 text-ink-black/70">
            <Flame class="w-3.5 h-3.5 text-cinnabar-red" />
            <span class="font-bold text-ink-black/55">美味</span>
            <span class="font-bold text-ink-black">{meta.delicious}/5</span>
          </div>
          <div class="inline-flex items-center gap-1.5 rounded-full bg-deep-sea/8 border border-deep-sea/20 px-2.5 py-1 text-ink-black/70">
            <ShieldAlert class="w-3.5 h-3.5 text-deep-sea" />
            <span class="font-bold text-ink-black/55">危险</span>
            <span class="font-bold text-ink-black">{meta.danger}/5</span>
          </div>
        </div>

        <!-- Ancient text segment -->
        <section class="bg-paper-light/80 border border-paper-dark/35 p-3 rounded-sm">
          <h3 class="font-display text-sm font-bold text-deep-sea flex items-center gap-1.5 mb-1.5">
            <BookOpen class="w-3.5 h-3.5" /> 原文
          </h3>
          <div class="font-display text-xs md:text-sm leading-relaxed text-ink-black/85 tracking-wide bg-white/45 border-l-2 border-cinnabar-red/50 px-3 py-2">
            {creature.description}
          </div>
        </section>

        <!-- Fun note with lightweight identification context -->
        <section class="bg-paper-light border border-paper-dark/35 p-3 md:p-4 rounded-sm">
          <h3 class="font-display text-base font-bold text-deep-sea border-b border-paper-dark/20 pb-1.5">
            现代考证
          </h3>
          <div class="mt-2.5 space-y-2.5 text-xs font-sans text-ink-black/85 leading-relaxed">
            {modernImage && (
              <figure class="float-right ml-3 mb-2 w-28 sm:w-32 md:w-36">
                <div class="bg-white border border-paper-dark/40 aspect-[4/3] rounded-sm overflow-hidden">
                  <img
                    src={modernImage}
                    alt={`${creature.name}现代候选真物图`}
                    class="object-cover w-full h-full opacity-90"
                    loading="lazy"
                  />
                </div>
                <figcaption class="mt-1 text-[10px] leading-snug text-ink-black/45 text-center">
                  现代候选真物
                  {identification?.modernImageSource && (
                    <>
                      {' · '}
                      <a href={identification.modernImageSource} class="hover:text-cinnabar-red" target="_blank" rel="noreferrer">
                        来源
                      </a>
                    </>
                  )}
                </figcaption>
              </figure>
            )}
            {identification ? (
              <>
                <p>
                  这条多被看作{identification.candidateModernName}。
                </p>
                <p>
                  {identification.rationale}
                </p>
                {identification.caveats && (
                  <p>{identification.caveats}</p>
                )}
              </>
            ) : (
              <p>{meta.modernInfo}</p>
            )}
            <p>
              <span class="font-bold text-cinnabar-red">食味：</span>{meta.deliciousComment}
            </p>
          </div>
        </section>

      </div>
    </div>
  </div>
</Layout>

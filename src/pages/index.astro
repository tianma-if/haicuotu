---
import Layout from '../layouts/Layout.astro';
import CreatureGallery from '../components/CreatureGallery';
import { illustratedCreatures } from '../utils/data';

const title = "海错图数字化图鉴 - 清代聂璜海洋生物古籍图谱";
const description = "在线浏览清代聂璜《海错图》数字化图鉴，收录海洋生物、海怪异兽、原文释义与现代生物考证，适合古籍、博物、海洋文化爱好者检索阅读。";
---

<Layout
  title={title}
  description={description}
  canonical="/"
  image="/images/vol1/page_35.webp"
  imageAlt="《海错图》数字化图鉴中的海洋生物插图"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": title,
    "description": description,
    "url": new URL("/", Astro.site).toString(),
    "inLanguage": "zh-CN",
    "isPartOf": {
      "@type": "WebSite",
      "name": "海错图数字化图鉴",
      "url": new URL("/", Astro.site).toString()
    },
    "about": ["海错图", "聂璜", "清代古籍", "海洋生物"]
  }}
>
  <CreatureGallery client:load initialCreatures={illustratedCreatures} />

  <!-- SEO and Project Introduction Section -->
  <section class="mt-12 border-t border-paper-dark/30 pt-10 pb-6 space-y-8 max-w-4xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-ink-black/80 font-sans text-sm leading-relaxed">
      <div class="space-y-4">
        <h2 class="font-display text-xl font-black text-deep-sea border-b border-paper-dark/40 pb-2">
          关于《海错图》与数字化项目
        </h2>
        <p>
          <strong>《海错图》</strong>是由清代画家聂璜绘制的海洋生物图谱，共分四册，收录了 300 多种光怪陆离的真实与传说海洋生物。“错”者，杂也，指代海洋中品类繁多的奇特生物。本项目是一个<strong>开源数字化图鉴与对齐审计项目</strong>。
        </p>
        <p>
          传统古籍数字化往往面临多物种同框、排版错乱和图文错配（例如飞鱼与铜盆鱼图文颠倒）的挑战。我们通过高精度裁剪算子与人工校验，重建了这套 100% 精确的<strong>“单图-单物种”映射数据库</strong>。
        </p>
      </div>

      <div class="space-y-4">
        <h2 class="font-display text-xl font-black text-deep-sea border-b border-paper-dark/40 pb-2">
          探索与数字化特色
        </h2>
        <ul class="list-disc pl-5 space-y-1.5">
          <li><strong>279 个独立图鉴条目</strong>：全面整理四册古籍，提供无杂质的清晰插图裁剪。</li>
          <li><strong>现代物种考证</strong>：为古籍中的神秘海怪（如人鱼、海驴）及真实鱼类对照现代学名、置信度及考证依据。</li>
          <li><strong>美味与危险指数</strong>：结合聂璜在书中提及的食用口感与危险性，提供趣味性的美味指数和危险度评级。</li>
          <li><strong>每日海怪运势签</strong>：支持在 <a href="/fortune" class="text-cinnabar-red hover:underline font-bold">运势抽签页面</a> 抽取你的今日海洋灵兽，体验国风互动。</li>
        </ul>
      </div>
    </div>

    <div class="bg-paper-light border border-paper-dark/40 p-4 rounded-sm text-xs text-ink-black/60 text-center font-sans space-y-1">
      <p class="font-bold text-deep-sea">古籍出处与版权说明</p>
      <p>
        《海错图》第一至三册现藏于北京故宫博物院，第四册现藏于台北故宫博物院。本项目切片基于公开的历史文献扫描图像进行数字化整理，仅供数字人文研究、博物学学习及文化交流使用。
      </p>
    </div>
  </section>
</Layout>

---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string | null;
  imageAlt?: string;
  type?: 'website' | 'article';
  keywords?: string[];
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  googleSiteVerification?: string;
  bingSiteVerification?: string;
}

const { 
  title = "海错图数字化图鉴 - 发现东方海洋神秘生物", 
  description = "清代画家聂璜手绘的海洋生物图鉴《海错图》开源数字化版本。探索三百年前的神秘海怪、珍奇鱼类，支持古今生物对照、美味指数、每日运势抽签，一键生成精美海报分享。",
  canonical,
  image = "/images/vol1/page_35.webp",
  imageAlt = "《海错图》数字化图鉴插图",
  type = "website",
  keywords = ["海错图", "聂璜", "古籍数字化", "故宫博物院", "海洋生物", "海怪", "中国古籍", "国风图鉴"],
  structuredData,
  googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION,
  bingSiteVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION
} = Astro.props;

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, siteUrl).toString();
const imageUrl = image ? new URL(image, siteUrl).toString() : undefined;
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html' || Astro.url.pathname === '';
const jsonLd = structuredData ?? {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "海错图数字化图鉴",
  "url": new URL("/", siteUrl).toString(),
  "inLanguage": "zh-CN",
  "description": "清代聂璜《海错图》的开源数字化图鉴，收录海洋生物、异兽与古今考证信息。"
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- SEO Optimization -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="author" content="Haicuotu Project" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="googlebot" content="index, follow, max-image-preview:large" />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    {bingSiteVerification && <meta name="msvalidate.01" content={bingSiteVerification} />}
    <meta name="theme-color" content="#b23a2f" />
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="海错图数字化图鉴" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    {imageUrl && <meta property="og:image:alt" content={imageAlt} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Fonts for Modern Typography & Noto Serif SC for Elegant Chinese Serif -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700;900&family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
  </head>
  <body class="paper-scroll text-ink-black min-h-screen flex flex-col font-sans selection:bg-cinnabar-red selection:text-paper-light">
    <!-- Header -->
    <header class="border-b border-paper-dark/30 py-2 px-4 md:px-8 bg-paper-light/90 backdrop-blur-md sticky top-0 z-40">
      <div class="max-w-6xl mx-auto flex flex-row justify-between items-center gap-3 md:gap-4">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group">
          <div class="bg-cinnabar-red text-paper-light w-8 h-8 flex items-center justify-center font-display text-lg font-bold rounded-sm shadow-md group-hover:scale-105 transition-transform duration-300">
            海
          </div>
          <div>
            {isHome ? (
              <h1 class="font-display text-lg md:text-xl font-black tracking-wide leading-none">海错图</h1>
            ) : (
              <span class="font-display text-lg md:text-xl font-black tracking-wide leading-none block">海错图</span>
            )}
            <p class="hidden sm:block text-[11px] text-ink-black/60 uppercase tracking-widest font-sans leading-tight">Facsimile Digital Album</p>
          </div>
        </a>

        <!-- Navigation Links -->
        <nav class="flex items-center gap-3 md:gap-4 font-display text-sm md:text-base font-bold">
          <a href="/" class="inline-flex h-7 items-center hover:text-cinnabar-red transition-colors duration-300">画廊图鉴</a>
          <a href="/fortune" class="inline-flex h-7 items-center gap-1 hover:text-cinnabar-red transition-colors duration-300">
            运势签 <span class="inline-flex h-4 items-center bg-cinnabar-red text-paper-light text-[10px] px-1 rounded-full uppercase tracking-tighter">New</span>
          </a>
          <a href="https://github.com/tianma-if/haicuotu" target="_blank" rel="noopener noreferrer" aria-label="GitHub 仓库" title="GitHub 仓库" class="hidden sm:inline-flex w-7 h-7 items-center justify-center rounded-full border border-ink-black/20 bg-paper-light/50 text-ink-black/75 hover:text-cinnabar-red hover:bg-paper-dark/20 transition-colors duration-300">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.59 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.38-3.37-1.38-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.04 1.03-2.76-.1-.26-.45-1.31.1-2.72 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0 1 12 6.95c.85 0 1.7.12 2.5.34 1.9-1.33 2.74-1.05 2.74-1.05.55 1.41.2 2.46.1 2.72.64.72 1.03 1.64 1.03 2.76 0 3.95-2.34 4.82-4.57 5.08.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.59.69.49A10.14 10.14 0 0 0 22 12.25C22 6.59 17.52 2 12 2Z" />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <!-- Main Content Slot -->
    <main class="flex-grow max-w-6xl w-full mx-auto px-4 md:px-8 py-4 md:py-5">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-paper-dark/40 py-5 md:py-6 px-4 md:px-8 bg-deep-sea text-paper-light">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-paper-light/70">
        <div class="text-center md:text-left">
          <p class="font-display text-sm font-bold mb-0.5 leading-relaxed">《海错图》由清代聂璜绘，现分藏于北京故宫博物院（一至三册）与台北故宫博物院（第四册）</p>
          <p class="font-sans text-[11px] leading-relaxed">本项目为开源数字化呈现，由 magic-pdf 支持图文智能提取，部署于 Cloudflare Pages。</p>
        </div>
        <div class="flex items-center gap-3 font-sans text-[11px]">
          <a href="https://github.com/tianma-if/haicuotu" class="hover:underline hover:text-white">GitHub 仓库</a>
          <span>•</span>
          <span>© 2026 Haicuotu Project. All Rights Reserved.</span>
        </div>
      </div>
    </footer>
  </body>
</html>
